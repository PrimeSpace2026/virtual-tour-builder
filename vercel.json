{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Permissions-Policy",
          "value": "fullscreen=*, camera=*, microphone=*, gyroscope=*, accelerometer=*, xr-spatial-tracking=*"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/share/:id", "destination": "https://back-end-tp6x.onrender.com/og/view/:id" },
    { "source": "/api/(.*)", "destination": "https://back-end-tp6x.onrender.com/api/$1" },
    { "source": "/mp-models/(.*)", "destination": "https://static.matterport.com/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
